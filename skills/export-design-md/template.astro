---
// design-preview.astro — template for export-design-md skill
// Replace [Project Name], [Description], [Date], and all placeholder sections
// with actual content from DESIGN.md before writing to src/pages/design-preview.astro.

// If the project has a layout component, import it here:
// import Layout from '../layouts/Layout.astro';
// Otherwise, this page renders as a standalone full-document page.

const title = "[Project Name] Design System";
const description = "[Description]";
const generatedDate = "[Date]";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Copy <link> tags from the project's existing pages (fonts, etc.) -->
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <!-- Header -->
    <header class="top-0 z-10 sticky bg-white border-gray-200 border-b">
      <div
        class="flex justify-between items-center mx-auto px-6 py-4 max-w-4xl"
      >
        <span class="font-semibold text-lg tracking-wide">[Project Name]</span>
        <nav aria-label="Section navigation">
          <ul class="flex items-center gap-6 text-gray-500 text-base">
            <li>
              <a href="#colors" class="hover:text-gray-900 transition-colors"
                >Colors</a>
            </li>
            <li>
              <a
                href="#typography"
                class="hover:text-gray-900 transition-colors">Typography</a>
            </li>
            <li>
              <a href="#spacing" class="hover:text-gray-900 transition-colors"
                >Spacing</a>
            </li>
            <li>
              <a href="#shapes" class="hover:text-gray-900 transition-colors"
                >Shapes</a>
            </li>
            <li>
              <a
                href="#components"
                class="hover:text-gray-900 transition-colors">Components</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="mx-auto px-6 py-12 max-w-4xl">
      <!-- Breadcrumb -->
      <p class="mb-8 text-gray-400 text-sm">
        ← <a href="/" class="hover:text-gray-700 transition-colors"
          >Back to project</a
        >
      </p>

      <!-- Article header -->
      <div class="mb-10">
        <span
          class="inline-block bg-gray-100 mb-4 px-3 py-1 rounded-full font-medium text-gray-500 text-xs uppercase tracking-widest"
          >Design System</span
        >
        <h1 class="mb-4 font-medium text-4xl leading-none">
          [Project Name]<br />Design System
        </h1>
        <p class="text-gray-500 text-base leading-snug">{description}</p>
        <p class="mt-3 text-gray-400 text-sm">Generated {generatedDate}</p>
      </div>

      <hr class="mb-12 border-gray-200" />

      <!-- Overview -->
      <section class="mb-16">
        <p class="font-medium text-gray-600 text-base">
          [Overview text from DESIGN.md]
        </p>
      </section>

      <!-- 01 Colors -->
      <section id="colors" class="mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <span
            class="font-medium text-gray-400 text-xs uppercase tracking-widest"
            >01</span
          >
          <h2 class="font-normal text-2xl">Colors</h2>
        </div>

        <div class="gap-4 grid grid-cols-3 mb-8">
          <!-- Primary -->
          <div>
            <div style="background:#2957c8;height:7rem;border-radius:0.75rem;">
            </div>
            <p class="mt-2 font-medium text-sm">Primary</p>
            <p class="font-mono text-gray-400 text-xs">#2957c8</p>
          </div>
          <!-- Secondary -->
          <div>
            <div style="background:#1ba39c;height:7rem;border-radius:0.75rem;">
            </div>
            <p class="mt-2 font-medium text-sm">Secondary</p>
            <p class="font-mono text-gray-400 text-xs">#1ba39c</p>
          </div>
          <!-- (add more swatches as needed) -->
        </div>

        <p class="text-gray-600 text-sm leading-7">
          [Colors section text from DESIGN.md]
        </p>
      </section>

      <!-- 02 Typography -->
      <section id="typography" class="mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <span
            class="font-medium text-gray-400 text-xs uppercase tracking-widest"
            >02</span
          >
          <h2 class="font-normal text-2xl">Typography</h2>
        </div>

        <div class="flex flex-col gap-8 mb-8">
          <!-- h1 sample -->
          <div class="pb-6 border-gray-100 border-b">
            <p class="mb-3 font-mono text-gray-400 text-xs">
              h1 — [fontFamily] / [fontSize] / [fontWeight]
            </p>
            <p style="font-size:3.75rem;font-weight:400;line-height:1.3;">
              Heading sample
            </p>
          </div>
          <!-- body-md sample -->
          <div class="pb-6 border-gray-100 border-b">
            <p class="mb-3 font-mono text-gray-400 text-xs">
              body-md — [fontFamily] / [fontSize] / [fontWeight]
            </p>
            <p class="text-gray-700 text-sm leading-7">
              Body text sample. Displayed with line-height tuned for readability
              and comfortable spacing.
            </p>
          </div>
          <!-- label-sm sample -->
          <div>
            <p class="mb-3 font-mono text-gray-400 text-xs">
              label-sm — [fontFamily] / [fontSize] / ls [letterSpacing]
            </p>
            <p
              style="font-size:0.75rem;letter-spacing:0.24em;text-transform:uppercase;"
            >
              Label sample
            </p>
          </div>
        </div>

        <p class="text-gray-600 text-sm leading-7">
          [Typography section text from DESIGN.md]
        </p>
      </section>

      <!-- 03 Spacing -->
      <section id="spacing" class="mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <span
            class="font-medium text-gray-400 text-xs uppercase tracking-widest"
            >03</span
          >
          <h2 class="font-normal text-2xl">Spacing</h2>
        </div>

        <div class="flex flex-col gap-4">
          <!-- xs: 8px -->
          <div class="flex items-center gap-4">
            <div
              style="width:8px;height:1rem;background:#2957c8;border-radius:2px;flex-shrink:0;"
            >
            </div>
            <span class="w-8 font-mono text-gray-700 text-sm">xs</span>
            <span class="text-gray-400 text-sm">8px</span>
          </div>
          <!-- (add more spacing tokens as needed) -->
        </div>
      </section>

      <!-- 04 Shapes -->
      <section id="shapes" class="mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <span
            class="font-medium text-gray-400 text-xs uppercase tracking-widest"
            >04</span
          >
          <h2 class="font-normal text-2xl">Shapes</h2>
        </div>

        <div class="gap-6 grid grid-cols-4 mb-8">
          <!-- sm: 16px -->
          <div class="flex flex-col items-center gap-3">
            <div
              style="width:5rem;height:5rem;border-radius:16px;background:linear-gradient(135deg,#2957c8,#1ba39c);"
            >
            </div>
            <div class="text-center">
              <p class="font-medium text-sm">sm</p>
              <p class="font-mono text-gray-400 text-xs">16px</p>
            </div>
          </div>
          <!-- (add more rounded tokens as needed) -->
        </div>

        <p class="text-gray-600 text-sm leading-7">
          [Shapes section text from DESIGN.md]
        </p>
      </section>

      <!-- 05 Components -->
      <section id="components" class="mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <span
            class="font-medium text-gray-400 text-xs uppercase tracking-widest"
            >05</span
          >
          <h2 class="font-normal text-2xl">Components</h2>
        </div>

        <!-- Component previews go here -->

        <p class="text-gray-600 text-sm leading-7">
          [Components section text from DESIGN.md]
        </p>
      </section>

      <!-- 06 Do's and Don'ts -->
      <section id="guidelines" class="mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <span
            class="font-medium text-gray-400 text-xs uppercase tracking-widest"
            >06</span
          >
          <h2 class="font-normal text-2xl">Do's and Don'ts</h2>
        </div>

        <div class="flex flex-col gap-3">
          <div class="flex gap-2 text-sm leading-7">
            <span class="font-bold text-green-600 shrink-0">✓</span>
            <p class="text-gray-700">[Do item]</p>
          </div>
          <div class="flex gap-2 text-sm leading-7">
            <span class="font-bold text-red-400 shrink-0">✗</span>
            <p class="text-gray-700">[Don't item]</p>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-gray-200 border-t">
      <div
        class="flex justify-between items-center mx-auto px-6 py-6 max-w-4xl text-gray-400 text-sm"
      >
        <p>[Project Name] Design System</p>
        <p>Generated {generatedDate}</p>
      </div>
    </footer>
  </body>
</html>
